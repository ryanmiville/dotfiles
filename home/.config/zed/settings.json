// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "preview_tabs": {
    "enable_preview_from_multibuffer": false,
    "enable_preview_from_project_panel": false,
    "enabled": false,
  },
  "cli_default_open_behavior": "new_window",
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "agent_servers": {
    "pi-sdk-acp": {
      "type": "custom",
      "command": "node",
      "args": ["/Users/ryanmiville/dev/pi-sdk-acp/dist/index.js"],
    },
    "pi-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
      "default_mode": "plan",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
  },
  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
    "show": false,
  },
  "pane_split_direction_vertical": "right",
  "toolbar": {
    "quick_actions": false,
    "selections_menu": false,
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
  ],
  "file_finder": {
    "modal_max_width": "large",
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-6-thinking-latest",
      "enable_thinking": false,
    },
    "tool_permissions": {
      "default": "allow",
    },
    "dock": "left",
    "play_sound_when_agent_done": "always",
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-3-haiku-20240307",
    },
    "button": false,
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "outline_panel": {
    "dock": "right",
    "button": false,
  },
  "terminal": {
    "shell": "system",
    "dock": "bottom",
    "button": false,
    "env": {
      "EDITOR": "zed --wait",
    },
  },
  "project_panel": {
    "dock": "right",
    "button": true,
    "auto_reveal_entries": false,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Tokyo Night",
  },
  "theme_overrides": {
    "Tokyo Night": {
      "border.variant": "#16161E",
      "border": "#16161E",
      // "title_bar.background": "",
      "panel.focused_border": "#C0CAF5",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
  },
  "telemetry": {
    "metrics": false,
  },
  "vim_mode": true,
  "which_key": { "enabled": true },
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },
  "languages": {
    "Python": {
      "language_servers": ["basedpyright"],
      "allow_rewrap": "in_selections",
    },
  },
  "relative_line_numbers": "enabled",
  "ui_font_size": 16,
  "ui_font_family": "Maple Mono NF",
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_size": 16,
  "agent_ui_font_size": 16,
  "soft_wrap": "none",
  "jupyter": {
    "kernel_selections": {
      "python": "myuv",
      "typescript": "deno",
      "javascript": "deno",
    },
  },
  "title_bar": {
    "show_branch_name": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_user_picture": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "auto_signature_help": true,
  "use_system_window_tabs": false,
  "hover_popover_enabled": false,
  "extend_comment_on_newline": false,
  "close_on_file_delete": true,
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false,
  },
  "cursor_blink": false,
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "inline_code_actions": false,
}
