{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": true,
  "disabled_providers": [
    "google-vertex-anthropic",
    "gitlab"
  ],
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details",
    },
    "opencode-local": {
      "path": "~/.local/share/opencode",
      "description": "Contains opencode logs and data",
    },
  },
  "mcp": {
    "servers": {
      "context7": {
        "type": "remote",
        "url": "https://mcp.context7.com/mcp",
        "disabled": true
      },
      "grep_app": {
        "type": "remote",
        "url": "https://mcp.grep.app",
        "disabled": true
      },
      "opensrc": {
        "type": "local",
        "command": [
          "npx",
          "-y",
          "opensrc-mcp"
        ],
        "disabled": true
      },
      "playwriter": {
        "type": "local",
        "command": [
          "npx",
          "-y",
          "playwriter@latest"
        ],
        "disabled": true
      },
      "atlassian-rovo": {
        "type": "remote",
        "url": "https://mcp.atlassian.com/v1/mcp",
        "disabled": true,
        "oauth": {}
      }
    }
  },
  "permissions": [
    {
      "action": "external_directory",
      "resource": "*",
      "effect": "allow"
    },
    {
      "action": "*",
      "resource": "*",
      "effect": "allow"
    }
  ],
  "plugins": [
    "@plannotator/opencode@latest"
  ]
}