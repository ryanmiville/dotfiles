{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": true,
  "disabled_providers": [
    "google-vertex-anthropic",
    "gitlab"
  ],
  "agents": {
    "explore": {
      "model": "anthropic/claude-haiku-4-5"
    }
  },
  "mcp": {
    "servers": {
      "context7": {
        "type": "remote",
        "url": "https://mcp.context7.com/mcp",
        "disabled": true
      },
      "grep_app": {
        "type": "remote",
        "url": "https://mcp.grep.app",
        "disabled": true
      },
      "opensrc": {
        "type": "local",
        "command": [
          "npx",
          "-y",
          "opensrc-mcp"
        ],
        "disabled": true
      },
      "playwriter": {
        "type": "local",
        "command": [
          "npx",
          "-y",
          "playwriter@latest"
        ],
        "disabled": true
      },
      "atlassian-rovo": {
        "type": "remote",
        "url": "https://mcp.atlassian.com/v1/mcp",
        "disabled": true,
        "oauth": {}
      }
    }
  },
  "permissions": [
    {
      "action": "*",
      "resource": "*",
      "effect": "allow"
    }
  ],
  "plugins": [
    "@plannotator/opencode@latest"
  ]
}